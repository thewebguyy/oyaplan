# ─────────────────────────────────────────────
# Supabase — public, safe to expose in client bundles
# RLS policies enforce data security at the database layer
# Obtain from: Supabase dashboard → Project Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────
# Sentry — error monitoring
# Obtain from: Sentry dashboard → Settings → Projects → Client Keys (DSN)
# ─────────────────────────────────────────────

# Server-side error capture (Node.js and Edge runtimes).
# Never expose to the client — use NEXT_PUBLIC_SENTRY_DSN for browser.
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Client-side error capture (browser bundle).
# DSN is safe to expose — it is a write-only ingest endpoint, not an API key.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Required for source map upload to Sentry (build-time only, never runtime).
# Obtain from: Sentry dashboard → Settings → Auth Tokens → Create New Token
# Set in Vercel environment for Production. Set in CI secrets if source maps in CI are desired.
# When absent, source map upload is skipped silently — error capture still works.
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Sentry org and project slugs — required only when SENTRY_AUTH_TOKEN is set.
# Obtain from: Sentry dashboard → Settings → Organization slug and project slug.
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# ─────────────────────────────────────────────
# Admin — server-only, never expose to the client
# ─────────────────────────────────────────────

# DEPRECATED — was used for query-param admin auth (?key=VALUE).
# Retained for reference during migration period. Remove once
# all instances of the old auth pattern are confirmed gone.
# ADMIN_KEY=your-old-key-here
